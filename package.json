{
  "name": "streamify-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev":    "next dev",
    "build":  "next build",
    "start":  "next start",
    "lint":   "next lint",
    "cf:build": "npx @cloudflare/next-on-pages",
    "cf:preview": "npx @cloudflare/next-on-pages && wrangler pages dev .vercel/output/static",
    "cf:deploy": "npx @cloudflare/next-on-pages && wrangler pages deploy .vercel/output/static --project-name streamify"
  },
  "dependencies": {
    "next":       "15.1.0",
    "react":      "^19.0.0",
    "react-dom":  "^19.0.0",
    "hls.js":     "^1.5.13",
    "zustand":    "^5.0.2",
    "idb":        "^8.0.0",
    "clsx":       "^2.1.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/node":                 "^22",
    "@types/react":                "^19",
    "@types/react-dom":            "^19",
    "typescript":                  "^5",
    "tailwindcss":                 "^3.4.0",
    "postcss":                     "^8",
    "autoprefixer":                "^10",
    "@cloudflare/next-on-pages":   "^1.13.10",
    "wrangler":                    "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
